    }

    // Fonction pour g├Еrer l'entr├Еe de texte dans le simulateur de terminal
    function handleCommand(event) {
        if (event.key === 'Enter') {
            let input = document.getElementById('cmdInput');
            let value = input.value.trim();
            
            if (value !== "") {
                if (!isNaN(value)) {
                    runTool(value);
                } else if (value.toLowerCase() === 'b') {
                    alert("Retour en arri├еre...");
                } else if (value.toLowerCase() === 'i') {
                    alert("Interface Multi-Tool v3 - D├Еvelopp├Еe pour le fun et le design.");
                } else {
                    alert("Commande '" + value + "' non reconnue.");
                }
                input.value = ""; // Vide le prompt apr├еs ex├Еcution
            }
        }
    }
