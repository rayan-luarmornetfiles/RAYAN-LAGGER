        /* Importation d'une police style terminal r├Еtro */
        @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;700&display=swap');

        body {
            background-color: #0b0202; /* Noir tr├еs profond avec une nuance de rouge */
            color: #ffffff;
            font-family: 'Fira Code', monospace;
            padding: 20px;
            margin: 0;
            user-select: none;
        }

        /* Effet de scanline style vieil ├Еcran cathodique (optionnel mais styl├Е) */
        body::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 2;
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
        }

        /* Code couleur */
        .red { color: #ff3333; font-weight: bold; }
        .white { color: #ffffff; }
        .gray { color: #555555; }

        /* Banni├еre ASCII */
        .banner {
            text-align: center;
            color: #ff2222;
            font-size: 12px;
            white-space: pre;
            line-height: 1.2;
            margin-bottom: 5px;
            text-shadow: 0 0 10px rgba(255, 0, 0, 0.5);
        }

        .subtitle {
            text-align: center;
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 30px;
        }

        /* Structure du Menu */
        .menu-top {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }

        .separator-line {
            color: #ff3333;
            white-space: pre;
            line-height: 1;
        }

        .category-box {
            text-align: center;
            margin: -10px 0 15px 0;
        }
        .box-title {
            border: 1px solid #ff3333;
            padding: 2px 15px;
            display: inline-block;
            background-color: #0b0202;
        }

        /* Grille des options (3 colonnes) */
        .options-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px 20px;
            padding-left: 25px;
            border-left: 1px solid #ff3333;
            margin-left: 1px;
        }

        .option-item {
            cursor: pointer;
            transition: all 0.2s ease;
        }

        /* Effet au survol des options */
        .option-item:hover {
            color: #ff3333;
            text-shadow: 0 0 5px rgba(255, 51, 51, 0.5);
            transform: translateX(5px);
        }

        .option-num {
            margin-right: 8px;
        }

        .menu-bottom-line {
            color: #ff3333;
            margin-top: 5px;
        }

        /* Prompt de commande en bas */
        .prompt-section {
            margin-top: 30px;
        }
        .prompt-user {
            color: #ff3333;
        }
        .prompt-input-container {
            display: flex;
            align-items: center;
            margin-top: 5px;
        }
        .prompt-symbol {
            color: #ff3333;
            margin-right: 10px;
        }
        .command-input {
            background: transparent;
            border: none;
            color: #ffffff;
            font-family: 'Fira Code', monospace;
            font-size: 1rem;
            width: 100%;
            outline: none;
        }
    </style>
